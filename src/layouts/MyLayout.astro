---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";

const { title = "JoacoDev", animation = "grid" } = Astro.props;
---

<html lang="en" data-theme={animation}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0" />
    <title>{title}</title>

    <ClientRouter />
  </head>

  <body class="bg-zinc-950 text-zinc-100 font-main antialiased selection:bg-amber-500/30 selection:text-white">

    <div class="fixed inset-0 bg-[linear-gradient(to_right,#1f293715_1px,transparent_1px),linear-gradient(to_bottom,#1f293715_1px,transparent_1px)] bg-[size:4rem_4rem] pointer-events-none"></div>

    <canvas id="pixel-transition-canvas" class="fixed inset-0 pointer-events-none z-[9999] w-full h-full"></canvas>

    <main class="relative z-10 min-h-screen w-full flex flex-col overflow-x-hidden">
      <div class="w-full flex-1 px-4 sm:px-6 md:px-8 mx-auto">
        <slot />
      </div>
    </main>

    <script type="module" src="/src/scripts/transitionHook.js"></script>

  </body>
</html>

<style is:global>
  /* =========================================================
     ⚡ FLUID RETRO TYPOGRAPHY COMPRESSION MATRIX
     Automatically computes and auto-scales font definitions 
     linearly based on minimum/maximum screens (Mobile to Desktop)
     ========================================================= */
  :root {
    /* Formula: clamp(MIN_SIZE, MOBILE_SIZE + VIEWPORT_GROWTH_FACTOR, MAX_SIZE)
      Scales flawlessly between 320px screens up to 1440px displays.
    */
    --font-size-xs: clamp(0.75rem, 0.7rem + 0.25vw, 0.875rem);
    --font-size-sm: clamp(0.875rem, 0.8rem + 0.35vw, 1rem);
    --font-size-base: clamp(1rem, 0.95rem + 0.45vw, 1.125rem);
    --font-size-lg: clamp(1.125rem, 1.05rem + 0.6vw, 1.35rem);
    --font-size-xl: clamp(1.35rem, 1.2rem + 0.85vw, 1.75rem);
    --font-size-2xl: clamp(1.75rem, 1.5rem + 1.25vw, 2.25rem);
    --font-size-3xl: clamp(2.25rem, 1.95rem + 1.75vw, 3.5rem);
    --font-size-4xl: clamp(3.25rem, 2.75rem + 2.5vw, 5.5rem);
  }

  /* Map standard Tailwind typography declarations to use global fluid design tokens */
  html, body {
    font-size: var(--font-size-base);
  }

  h1, .text-6xl, .text-5xl {
    font-size: var(--font-size-4xl) !important;
    line-height: 1.1 !important;
  }

  h2, .text-4xl, .text-3xl {
    font-size: var(--font-size-3xl) !important;
    line-height: 1.2 !important;
  }

  h3, .text-2xl {
    font-size: var(--font-size-2xl) !important;
    line-height: 1.3 !important;
  }

  p, .text-base {
    font-size: var(--font-size-base) !important;
    line-height: 1.6 !important;
  }

  span, time, .text-sm {
    font-size: var(--font-size-sm) !important;
  }

  /* Prevent elements from extending beyond mobile screen edges and creating horizontal scrollbars */
  *, ::before, ::after {
    max-width: 100vw;
    box-sizing: border-box;
  }

  img, video, canvas {
    max-width: 100%;
    height: auto;
  }
</style>