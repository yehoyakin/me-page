---
import { uiDictionary, type UiVariant } from "../../config/uiDictionary";

interface Props {
  class?: string;
  level?: 1 | 2 | 3 | 4 | 5 | 6;
  variant?: UiVariant;
}

const {
  class: customClass = "",
  level = 2,
  variant = "primary"
} = Astro.props;

const config = uiDictionary[variant];

const fontClass =
  config.font === "psx"
    ? "font-psx"
    : config.font === "title"
    ? "font-title"
    : "font-terminal";

const Tag = `h${level}` as any;
---

<Tag
  class:list={[
    fontClass,
    customClass
  ]}
>
  <slot />
</Tag>