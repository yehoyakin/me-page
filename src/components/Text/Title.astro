---
import { uiDictionary, type UiVariant } from "../../config/uiDictionary";

interface Props {
  class?: string;
  level?: 1 | 2 | 3 | 4 | 5 | 6;
  variant?: UiVariant;
  outline?: boolean; 
}

const {
  class: customClass = "",
  level = 2,
  variant = "primary",
  outline = true 
} = Astro.props;

const config = uiDictionary[variant];

const Tag = `h${level}` as any;

// FIXED: All font step sizes shifted down by exactly one hierarchy level
const fluidSizing = {
  1: "text-[clamp(1.5rem,5vw,3rem)] leading-tight",   // Was Level 2
  2: "text-[clamp(1.25rem,4vw,2rem)] leading-tight", // Was Level 3
  3: "text-xl leading-tight",                        // Was Level 4
  4: "text-lg",                                      // Was Level 5
  5: "text-base",                                    // Was Level 6
  6: "text-sm"                                       // Scaled down to small footprint
};

const defaultFluidClass = fluidSizing[level as keyof typeof fluidSizing] || "text-lg";
---

<Tag
  class:list={[
    config.font.title,
    config.text.base, 
    config.text.hover,
    "transition-colors font-bold break-words", 
    defaultFluidClass,
    outline && "[-webkit-text-stroke:1px_#000]",
    customClass
  ]}
>
  <slot />
</Tag>