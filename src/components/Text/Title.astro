---
// src/components/Text/Title.astro
interface Props {
  level?: "1" | "2" | "3" | "4" | "5" | "6";
  class?: string;
  className?: string;
}

const { level = "2" } = Astro.props;
const customClass = Astro.props.class ?? Astro.props.className ?? "";

// Choose the structural heading tag dynamically
const Tag = `h${level}` as any;
---

<Tag
  class:list={[
    "font-title font-bold tracking-wide text-zinc-100",
    customClass
  ]}
>
  <slot />
</Tag>