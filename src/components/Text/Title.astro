---
import { uiDictionary, type UiVariant } from "../../config/uiDictionary";

interface Props {
  class?: string;
  level?: 1 | 2 | 3 | 4 | 5 | 6;
  variant?: UiVariant;
  outline?: boolean; 
}

const {
  class: customClass = "",
  level = 2,
  variant = "primary",
  outline = false 
} = Astro.props;

const config = uiDictionary[variant];

const Tag = `h${level}` as any;

// Fluid handling rules depending on the header importance hierarchy level
const fluidSizing = {
  1: "text-[clamp(2rem,7vw,4.5rem)] leading-none", // Level 1 (Hero sizes down smoothly, maxes at 4.5rem)
  2: "text-[clamp(1.5rem,5vw,3rem)] leading-tight", // Level 2
  3: "text-[clamp(1.25rem,4vw,2rem)] leading-tight",
  4: "text-xl",
  5: "text-lg",
  6: "text-base"
};

const defaultFluidClass = fluidSizing[level as keyof typeof fluidSizing] || "text-xl";
---

<Tag
  class:list={[
    config.font.title,
    config.text.base, 
    config.text.hover,
    "transition-colors font-bold break-words", // 'break-words' acts as a safety shield against long words
    defaultFluidClass,
    outline && "[-webkit-text-stroke:1px_#000]",
    customClass
  ]}
>
  <slot />
</Tag>