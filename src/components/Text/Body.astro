---
// src/components/Text/Body.astro
import { uiDictionary, type UiVariant } from "../../config/uiDictionary";

interface Props {
  class?: string;
  className?: string;
  variant?: UiVariant;
}

const {
  class: customClass = "",
  className = "",
  variant = "primary"
} = Astro.props;

const config = uiDictionary[variant];

/* =========================
   FONT FROM DICTIONARY
   ========================= */
const fontClass =
  config.font === "psx"
    ? "font-psx"
    : config.font === "title"
    ? "font-title"
    : "font-terminal";
---

<p
  class:list={[
    fontClass,
    "text-base md:text-lg leading-relaxed max-w-2xl",
    customClass || className
  ]}
>
  <slot />
</p>