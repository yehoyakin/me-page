---
import { uiDictionary, type UiVariant } from "../../config/uiDictionary";

interface Props {
  class?: string;
  variant?: UiVariant;
}

const {
  class: customClass = "",
  variant = "primary"
} = Astro.props;

const config = uiDictionary[variant];
---

<p
  class:list={[
    config.fontClass,
    config.text.base,
    config.text.hover,
    "transition-colors",
    customClass
  ]}
>
  <slot />
</p>