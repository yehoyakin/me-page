---
import type { BlogPost } from "../../types/blog";

import Title from "../Text/Title.astro";
import Body from "../Text/Body.astro";
import Meta from "../Text/Body.astro";

type Props = {
  post: BlogPost;
};

const { post } = Astro.props;

const date = new Date(post.data.date);
---

<a
  href={`${import.meta.env.BASE_URL}/blog/${post.id}`}
  class="group relative block overflow-hidden rounded-xl border border-zinc-800 bg-zinc-950/40 p-8
         transition duration-700 ease-out
         hover:border-retro-primary/70
         hover:shadow-[0_0_80px_rgba(251,191,36,0.15)]"
>

  {/* BACKGROUND IMAGE */}
  {post.data.cardBackground && (
    <div class="absolute inset-0 overflow-hidden">
      <div
        class="absolute inset-0 scale-100 transition duration-[1600ms] ease-[cubic-bezier(0.22,1,0.36,1)]
               group-hover:scale-125 group-hover:brightness-110"
        style={`
          background-image: url('${post.data.cardBackground}');
          background-size: cover;
          background-position: center center;
        `}
      />

      {/* VIGNETTE */}
      <div
        class="absolute inset-0 transition duration-700
               bg-gradient-to-r from-zinc-950/90 via-zinc-900/50 to-zinc-950/30
               group-hover:from-zinc-950/70
               group-hover:via-zinc-900/20
               group-hover:to-zinc-950/10"
      />

      {/* GLOW */}
      <div
        class="absolute inset-0 opacity-0 transition duration-700
               group-hover:opacity-100
               bg-[radial-gradient(circle_at_center,rgba(251,191,36,0.12),transparent_70%)]"
      />

      {/* LIGHT SWEEP */}
      <div class="absolute inset-0 opacity-0 transition duration-700 pointer-events-none group-hover:opacity-100">
        <div
          class="absolute -left-1/2 top-0 h-full w-1/2 rotate-12
                 bg-gradient-to-r from-transparent via-white/10 to-transparent
                 blur-xl animate-[sweep_1.2s_ease-out]"
        />
      </div>
    </div>
  )}

  {/* CONTENT */}
  <div class="relative z-10 flex items-start justify-between gap-4">

    <div class="space-y-4 flex-1">

      <Meta
        class="text-sm text-zinc-500 transition duration-500 group-hover:text-retro-primary"
      >
        {date.toDateString()}
      </Meta>

      <Title
        level={2}
        class="mt-2 text-3xl transition duration-500 group-hover:text-retro-primary"
      >
        {post.data.title}
      </Title>

      <Body
        class="mt-4 text-zinc-400 transition duration-500 group-hover:text-zinc-300"
      >
        {post.data.description}
      </Body>

    </div>

  </div>

</a>