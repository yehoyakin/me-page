---
import type { BlogPost } from "../../types/blog";

import Title from "../Text/Title.astro";
import Body from "../Text/Body.astro";
import Meta from "../Text/Body.astro";

type Props = {
  post: BlogPost;
};

const { post } = Astro.props;

const date = new Date(post.data.date);
---

<a 
  href={`/blog/${post.id}`} 
  class="group block rounded-3xl border border-zinc-800 bg-zinc-950/40 p-8 transition hover:-translate-y-1 hover:border-retro-primary hover:bg-white/5 hover:shadow-[0_20px_60px_-30px_rgba(255,255,255,0.25)] relative overflow-hidden"
  style={post.data.cardBackground ? `background-image: url('${post.data.cardBackground}'); background-size: cover; background-position: center;` : undefined}
>
  {post.data.cardBackground && (
    <div class="absolute inset-0 bg-gradient-to-r from-zinc-950/80 via-zinc-900/40 to-transparent pointer-events-none" />
  )}        
  
  <div class="relative z-10 flex items-start justify-between gap-4">
    <div class="space-y-4 flex-1">
      <Meta class="text-sm text-zinc-500 transition group-hover:text-retro-primary">
        {date.toDateString()}
      </Meta>

      <Title level={2} class="text-3xl mt-2 transition group-hover:text-retro-primary">
        {post.data.title}
      </Title>

      <Body class="text-zinc-400 mt-4">
        {post.data.description}
      </Body>
    </div>
  </div>
</a>