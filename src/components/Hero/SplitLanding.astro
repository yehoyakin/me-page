---
import Body from "../Text/Body.astro";
import Portrait from "./MyImage.astro";
import Card from "./Card.astro";

interface CardData {
  href: string;
  tag: string;
  title: string;
  description: string;
  actionText: string;
  variant?: "primary" | "secondary";
  imageSrc: string;
}

interface Props {
  background: string;
  left: CardData;
  right: CardData;
  footerText?: string;
}

const {
  background,
  left,
  right,
  footerText = "",
} = Astro.props as Props;
---

<section class="relative flex-1 min-h-0 overflow-hidden">

  <div
    class="absolute inset-0 bg-cover bg-center mix-blend-luminosity opacity-20"
    style={`background-image: url('${background}')`}
  />

  <div class="absolute inset-0 bg-zinc-950/85" />

  <div class="relative z-10 flex h-full min-h-0 flex-col">

    <div class="grid flex-1 min-h-0 lg:grid-cols-2">

      <Card
        href={left.href}
        tag={left.tag}
        title={left.title}
        description={left.description}
        actionText={left.actionText}
        variant={left.variant ?? "primary"}
        class="border-b border-zinc-800/60 lg:border-b-0 lg:border-r"
      >
        <Portrait
          slot="background"
          src={left.imageSrc}
          shape="square"
          size="xl"
          crt={false}
          animate="float"
        />
      </Card>

      <Card
        href={right.href}
        tag={right.tag}
        title={right.title}
        description={right.description}
        actionText={right.actionText}
        variant={right.variant ?? "primary"}
      >
        <Portrait
          slot="background"
          src={right.imageSrc}
          shape="square"
          size="xl"
          crt={false}
          animate="float"
        />
      </Card>

    </div>

    <div class="shrink-0 border-t border-zinc-800/60 bg-zinc-950/50 px-8 py-6 backdrop-blur-md">
      <div class="mx-auto max-w-2xl text-center">
        <Body class="text-sm italic text-zinc-500">
          {footerText}
        </Body>
      </div>
    </div>

  </div>

</section>