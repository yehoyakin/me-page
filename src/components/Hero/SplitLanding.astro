---
import Body from "../Text/Body.astro";
import Portrait from "./MyImage.astro";
import Card from "./Card.astro";

interface CardData {
  href: string;
  tag: string;
  title: string;
  description: string;
  actionText: string;
  variant?: "primary" | "secondary";
  imageSrc: string;
}

interface Props {
  background: string;
  left: CardData;
  right: CardData;
  footerText?: string;
}

const {
  background,
  left,
  right,
  footerText = "",
} = Astro.props as Props;
---

{/* 💡 FIXED: Set to always allow vertical expansion when content inside the cards grows in length */}
<section class="relative flex-1 w-full h-full overflow-y-auto">

  <div
    class="absolute inset-0 bg-cover bg-center opacity-20 pointer-events-none"
    style={`background-image: url('${background}')`}
  />

  <div class="absolute inset-0 bg-zinc-950/85 pointer-events-none" />

  <div class="relative z-10 flex min-h-full flex-col justify-between">

    <div class="grid grid-cols-2 flex-1 w-full min-h-0">


      <div class="w-full h-full min-h-[340px]">
        <Card
          href={left.href}
          tag={left.tag}
          title={left.title}
          description={left.description}
          actionText={left.actionText}
          variant={left.variant ?? "primary"}

          class="h-full w-full border-r border-zinc-800/60"
        >
          <Portrait
            slot="background"
            src={left.imageSrc}
            shape="square"
            size="xl"
          />
        </Card>
      </div>

      {/* RIGHT CARD CONTAINER */}
      <div class="w-full h-full min-h-[340px]">
        <Card
          href={right.href}
          tag={right.tag}
          title={right.title}
          description={right.description}
          actionText={right.actionText}
          variant={right.variant ?? "primary"}
          class="h-full w-full"
        >
          <Portrait
            slot="background"
            src={right.imageSrc}
            shape="square"
            size="xl"
          />
        </Card>
      </div>

    </div>

    {/* FOOTER BAR */}
    <div class="shrink-0 border-t border-zinc-800/60 bg-zinc-950/50 px-8 py-4 sm:py-6 backdrop-blur-md">
      <div class="mx-auto max-w-2xl text-center">
        <Body class="text-sm italic text-zinc-500">
          {footerText}
        </Body>
      </div>
    </div>

  </div>

</section>