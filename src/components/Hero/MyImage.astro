---
// src/components/Hero/MyImage.astro
import { Image } from 'astro:assets';

interface Props {
  src: any;
  alt?: string;
  shape?: 'circle' | 'square' | 'squircle';
  size?: 'sm' | 'md' | 'lg' | 'xl';
  theme?: 'primary' | 'secondary' | 'terminal';
}

const {
  src,
  alt = "Portrait",
  shape = "circle",
  size = "md",
  theme = "primary",
} = Astro.props;

// Pure container classes - no animations, no complex setups
const baseClasses = "relative overflow-hidden border-4 bg-zinc-950 backdrop-blur-sm";

const shapeMap = {
  circle: "rounded-full",
  square: "rounded-none",
  squircle: "rounded-[2rem] md:rounded-[3.5rem]"
};

const sizeMap = {
  sm: "w-32 h-32 md:w-40 md:h-40",
  md: "w-56 h-56 md:w-72 md:h-72",
  lg: "w-72 h-72 md:w-96 md:h-96",
  xl: "w-full h-full absolute inset-0"
};

const themeMap = {
  primary: "border-retro-primary/80 shadow-[0_0_50px_rgba(251,191,36,0.2)]",
  secondary: "border-retro-secondary/80 shadow-[0_0_50px_rgba(34,211,238,0.2)]",
  terminal: "border-retro-terminal/80 shadow-[0_0_50px_rgba(74,222,128,0.2)]"
};

const dynamicContainerClasses = [
  baseClasses,
  shapeMap[shape],
  sizeMap[size],
  themeMap[theme]
].filter(Boolean).join(" ");

// 💡 FORCED: Every image now uses object-cover to completely fill the space without bars
const imgClasses = "w-full h-full object-contain select-none pointer-events-none";
---

<div class={dynamicContainerClasses}>
  <div class="w-full h-full flex items-center justify-center overflow-hidden">
    {typeof src === 'string' ? (
      <img
        src={src}
        alt={alt}
        class={imgClasses}
      />
    ) : (
      <Image
        src={src}
        alt={alt}
        class={imgClasses}
      />
    )}
  </div>
</div>