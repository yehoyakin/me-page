---
interface Props {
  href?: string;
  text?: string;
}

const { href = "${import.meta.env.BASE_URL}/", text = "← Back to home" } = Astro.props;
---

<a
  href={href}
  class="fixed top-6 left-6 z-50
         text-[color:var(--retro-primary)]
         hover:opacity-80 transition"
>
  <span>{text}</span>
</a>