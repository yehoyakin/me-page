---
// src/components/Hero/BackLink.astro or src/components/BackLink.astro

interface Props {
  href?: string;
  text?: string;
}

const { href, text = "← Back to home" } = Astro.props;

// 💡 Dynamically map the base URL so fallback addresses don't break production builds
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

// 💡 If a custom href is supplied, use it directly. Otherwise, safely use the homepage base route.
const resolvedHref = href || baseUrl;
---

<a
  href={resolvedHref}
  class="fixed top-6 left-6 z-50 font-mono text-sm uppercase tracking-wider
         text-[color:var(--retro-primary)]
         /* 💡 Low-res frame rate hover effect to stay uniform with your layout */
         transition-all duration-75 ease-[steps(2)]
         hover:translate-x-[-2px] hover:text-[color:var(--ui-invert)]
         /* 💡 Sharp 2D offset drop shadow text layer */
         [text-shadow:2px_2px_0px_rgba(0,0,0,1)]"
>
  <span>{text}</span>
</a>