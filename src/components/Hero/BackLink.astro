---
// src/components/BackLink.astro
interface Props {
  href?: string;
  text?: string;
}

const { href: propsHref, text = "← Back to home" } = Astro.props;

// 💡 This forces Astro to fall back if propsHref is missing OR empty ("")
const href = propsHref || `${import.meta.env.BASE_URL}/`;
---

<a
  href={href}
  class="fixed top-6 left-6 z-50
         text-[color:var(--retro-primary)]
         hover:opacity-80 transition"
>
  <span>{text}</span>
</a>