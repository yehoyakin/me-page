---
// src/components/Hero/InfoHeader.astro
import Title from "../Text/Title.astro";
import Portrait from "./MyImage.astro";
import Body from "../Text/Body.astro";

interface Props {
  name: string;
  description: string;
  portraitSrc: string;
  theme?: "primary" | "secondary" | "terminal";
}

const {
  name,
  description,
  portraitSrc,
  theme = "primary"
} = Astro.props;

const dynamicStyle = `--header-theme-color: var(--color-retro-${theme});`;
---

<div
  class="flex flex-col items-center justify-center text-center py-6 md:py-10 px-8 w-full"
  style={dynamicStyle}
>
  <Title level={1} class="text-2xl md:text-4xl tracking-[0.12em] uppercase">
    {name}
  </Title>

  <div class="flex justify-center mt-4">
    <Portrait
      src={portraitSrc}
      theme={theme}
      shape="square"
      size="md"
    />
  </div>

  <Body variant={theme} class="mt-3 text-sm tracking-widest uppercase">
    {description}
  </Body>
</div>

<style>
  .theme-label-color {
    color: var(--header-theme-color);
  }
</style>