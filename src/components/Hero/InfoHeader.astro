---
// src/components/Hero/InfoHeader.astro
import Title from "../Text/Title.astro";
import Portrait from "./MyImage.astro";
import Body from "../Text/Body.astro";

interface Props {
  name: string;
  description: string;
  portraitSrc: string;
  theme?: "primary" | "secondary" | "terminal";
}

const {
  name,
  description,
  portraitSrc,
  theme = "primary"
} = Astro.props;

// Correct: just forward the CSS variable reference (no rgb() wrapping here)
const dynamicStyle = `--header-theme-color: var(--color-retro-${theme});`;
---

<div
  class="flex flex-col items-center justify-center text-center py-24 px-8"
  style={dynamicStyle}
>
  <Title level={1} class="text-2xl md:text-4xl tracking-[0.12em] uppercase">
    {name}
  </Title>

  <div class="flex justify-center mt-6">
    <Portrait
      src={portraitSrc}
      theme={theme}
      shape="square"
      size="md"
      animate="none",
      crt={false}
    />
  </div>

  <Body variant={theme} class="mt-4 text-sm tracking-widest uppercase">
    {description}
  </Body>

</div>

<style>
  /* FIX: do NOT wrap with rgb(), the variable already resolves through CSS */
  .theme-label-color {
    color: var(--header-theme-color);
  }
</style>