---
import Title from "../Text/Title.astro";
import Body from "../Text/Body.astro";
import Link from "./Link.astro";

interface LinkItem {
  href: string;
  text?: string;
  image?: string;
}

interface Props {
  href?: string;
  links?: LinkItem[];
  tag?: string;
  title: string;
  description?: string;
  actionText?: string;
  backgroundImage?: string;
  class?: string;
}

const { href, links = [], tag = "", title, description = "", actionText = "", backgroundImage = "", class: extraClass = "" } = Astro.props as Props;

function iconFor(href?: string, image?: string) {
  if (image) {
    const key = image.toLowerCase();
    if (key.includes("/")) return `<img src="${image}" class="w-4 h-4 rounded-sm object-cover" />`;
    if (key.includes("steam")) return `<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\" class=\"w-4 h-4\"><path d=\"M12.5 10.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM12 2a10 10 0 100 20 10 10 0 000-20zM7.3 15.2a2.5 2.5 0 114.6-.2l4.1-2.3a3 3 0 10-.9-1.6l-4.3 2.4a2.5 2.5 0 11-3.5 1.3z\"/></svg>`;
    if (key.includes("gog")) return `<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\" class=\"w-4 h-4\"><path d=\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z\"/></svg>`;
    if (key.includes("epic")) return `<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\" class=\"w-4 h-4\"><path d=\"M5 4h14v2H5zM5 10h14v2H5zM5 16h14v2H5z\"/></svg>`;
    if (key.includes("xbox")) return `<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\" class=\"w-4 h-4\"><path d=\"M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm3.3 6.2c.5.3 1 .7 1.5 1.3-1 .6-2 1-3.2 1.1.5-.9 1-1.8 1.7-2.4zM8.7 8.2c.8.7 1.3 1.7 1.8 2.6C8.8 11 7.8 10.4 6.8 9.9c.5-.6 1-1 1.9-1.7z\"/></svg>`;
  }
  const host = (href || "").toLowerCase();
  if (host.includes("steam")) {
    return `<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\" class=\"w-4 h-4\"><path d=\"M12.5 10.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM12 2a10 10 0 100 20 10 10 0 000-20zM7.3 15.2a2.5 2.5 0 114.6-.2l4.1-2.3a3 3 0 10-.9-1.6l-4.3 2.4a2.5 2.5 0 11-3.5 1.3z\"/></svg>`;
  } else if (host.includes("gog")) {
    return `<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\" class=\"w-4 h-4\"><path d=\"M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z\"/></svg>`;
  } else if (host.includes("epic")) {
    return `<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\" class=\"w-4 h-4\"><path d=\"M5 4h14v2H5zM5 10h14v2H5zM5 16h14v2H5z\"/></svg>`;
  } else if (host.includes("xbox")) {
    return `<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\" class=\"w-4 h-4\"><path d=\"M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm3.3 6.2c.5.3 1 .7 1.5 1.3-1 .6-2 1-3.2 1.1.5-.9 1-1.8 1.7-2.4zM8.7 8.2c.8.7 1.3 1.7 1.8 2.6C8.8 11 7.8 10.4 6.8 9.9c.5-.6 1-1 1.9-1.7z\"/></svg>`;
  }
  return `<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 24 24\" fill=\"currentColor\" class=\"w-4 h-4\"><path d=\"M3.9 12a8.1 8.1 0 1116.2 0 8.1 8.1 0 01-16.2 0zM11 7h2v6h-2zM11 15h2v2h-2z\"/></svg>`;
}
---
{/* If multiple links are provided, render a card container with multiple Link components. Otherwise behave like the single-link card. */}
{links.length > 0 ? (
  <div class={`group block rounded-2xl overflow-hidden border border-zinc-800 bg-zinc-950/60 transition ${extraClass}`}>
    <div class="p-4">
      {backgroundImage && (
        <div class="w-full h-36 mb-4 overflow-hidden rounded-md">
          <img src={backgroundImage} class="w-full h-full object-cover" />
        </div>
      )}

      {tag && <div class="text-xs uppercase tracking-[0.2em] text-zinc-400">{tag}</div>}
      <Title level={4} class="mt-1">{title}</Title>
      {description && <Body class="mt-2 text-zinc-300 text-sm">{description}</Body>}

      <div class="mt-4 flex flex-col gap-2">
        {links.map((l: LinkItem) => (
          <Link href={l.href} text={l.text ?? "Open"} icon={iconFor(l.href, l.image)} external />
        ))}
      </div>
    </div>
  </div>
) : (
  <a href={href} target="_blank" class={`group block rounded-2xl overflow-hidden border border-zinc-800 bg-zinc-950/60 transition hover:scale-[1.01] ${extraClass}`}>
    <div class="flex items-center gap-4 p-4">
      {backgroundImage && (
        <div class="w-20 h-20 flex-shrink-0 overflow-hidden rounded-lg">
          <img src={backgroundImage} class="w-full h-full object-cover" />
        </div>
      )}

      <div class="flex-1">
        {tag && <div class="text-xs uppercase tracking-[0.2em] text-zinc-400">{tag}</div>}
        <Title level={4} class="mt-1">{title}</Title>
        <Body class="mt-2 text-zinc-300 text-sm">{description}</Body>
      </div>

      <div class="flex items-center">
        <Link href={href ?? "#"} text={actionText || "Open"} icon={iconFor(href, backgroundImage)} external />
      </div>
    </div>
  </a>
)}
