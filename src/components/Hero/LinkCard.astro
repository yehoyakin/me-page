---
import Title from "../Text/Title.astro";
import Body from "../Text/Body.astro";
import Link from "./Link.astro";

interface LinkItem {
  href: string;
  text?: string;
  image?: string;
}

interface Props {
  href?: string;
  links?: LinkItem[];
  tag?: string;
  title: string;
  description?: string;
  actionText?: string;
  backgroundImage?: string;
  class?: string;
}

const {
  href,
  links = [],
  tag = "",
  title,
  description = "",
  actionText = "",
  backgroundImage = "",
  class: extraClass = ""
} = Astro.props as Props;

/* ✅ BASE SAFE RESOLVER */
const base = import.meta.env.BASE_URL;

const resolve = (path?: string) =>
  path
    ? path.startsWith("http")
      ? path
      : `${base}${path.replace(/^\//, "")}`
    : "";

/* ❌ FIX: no HTML string injection */
function iconFor(href?: string, image?: string) {
  if (image) {
    return `
      <img 
        src="${resolve(image)}"
        class="w-4 h-4 rounded-sm object-cover"
        alt=""
      />
    `;
  }

  return `
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
      fill="currentColor" class="w-4 h-4">
      <path d="M3.9 12a8.1 8.1 0 1116.2 0 8.1 8.1 0 01-16.2 0z"/>
    </svg>
  `;
}
---

{links.length > 0 ? (
  <div class={`group block rounded-2xl overflow-hidden border border-zinc-800 bg-zinc-950/60 transition ${extraClass}`}>

    <div class="p-4">

      {backgroundImage && (
        <div class="w-full h-36 mb-4 overflow-hidden rounded-md">
          <img
            src={resolve(backgroundImage)}
            class="w-full h-full object-cover"
            alt=""
          />
        </div>
      )}

      {tag && (
        <div class="text-xs uppercase tracking-[0.2em] text-ui-muted">
          {tag}
        </div>
      )}

      <Title level={4} class="mt-1">
        {title}
      </Title>

      {description && (
        <Body class="mt-2 text-sm">
          {description}
        </Body>
      )}

      <div class="mt-4 flex flex-col gap-2">
        {links.map((l: LinkItem) => (
          <Link
            href={l.href}
            text={l.text ?? "Open"}
            icon={iconFor(l.href, l.image)}
            external
          />
        ))}
      </div>

    </div>
  </div>
) : (
  <a
    href={resolve(href)}
    target="_blank"
    class={`group block rounded-2xl overflow-hidden border border-zinc-800 bg-zinc-950/60 transition hover:scale-[1.01] ${extraClass}`}
  >
    <div class="flex items-center gap-4 p-4">

      {backgroundImage && (
        <div class="w-20 h-20 flex-shrink-0 overflow-hidden rounded-lg">
          <img
            src={resolve(backgroundImage)}
            class="w-full h-full object-cover"
            alt=""
          />
        </div>
      )}

      <div class="flex-1">
        {tag && (
          <div class="text-xs uppercase tracking-[0.2em] text-ui-muted">
            {tag}
          </div>
        )}

        <Title level={4} class="mt-1">
          {title}
        </Title>

        <Body class="mt-2 text-sm">
          {description}
        </Body>
      </div>

      <div class="flex items-center">
        <Link
          href={href ?? "#"}
          text={actionText || "Open"}
          icon={iconFor(href, backgroundImage)}
          external
        />
      </div>

    </div>
  </a>
)}