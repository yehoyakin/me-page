---
interface Props {
  href: string;
  text?: string;
  icon?: string;
  external?: boolean;
}

const { href, text = "", icon, external } = Astro.props;
---

<a
  href={href}
  target={external ? "_blank" : undefined}
  class="flex items-center gap-2 rounded-lg px-3 py-2 text-sm text-zinc-200
         hover:bg-white/5 transition"
>
  {icon && <span set:html={icon} />}
  <span>{text}</span>
</a>

<style>
/* =========================
   CRT GLOW (ICON)
   ========================= */

.group:hover svg {
  filter: drop-shadow(0 0 6px rgba(251, 191, 36, 0.75));
}

/* =========================
   SCANLINE EFFECT
   ========================= */

.scanline {
  position: absolute;
  left: -120%;
  top: 0;
  width: 120%;
  height: 100%;
  background: linear-gradient(
    to bottom,
    transparent,
    rgba(251, 191, 36, 0.25),
    transparent
  );
  transform: skewX(-20deg);
  opacity: 0;
}

.group:hover .scanline {
  animation: scanSweep 700ms ease-out;
  opacity: 1;
}

@keyframes scanSweep {
  0% { left: -120%; }
  100% { left: 120%; }
}
</style>