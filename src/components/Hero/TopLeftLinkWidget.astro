---
import Link from "./Link.astro";

interface LinkItem {
  href: string;
  text?: string;
  image?: string;
}

interface Props {
  links?: LinkItem[];
  title?: string;
  label?: string;
}

const {
  links = [],
  title = "",
  label = "Find it here",
} = Astro.props as Props;
---

<!-- GLOBAL HUD LAYER (DO NOT TOUCH LAYOUT) -->
<div class="fixed top-6 right-6 z-[999] pointer-events-none">
  <div class="pointer-events-auto relative group">

    <!-- TRIGGER -->
    <button
      class="flex items-center gap-2 rounded-full border border-zinc-800
             bg-zinc-950/80 px-4 py-2 text-sm font-medium text-zinc-100
             backdrop-blur-xl shadow-xl shadow-black/30
             transition duration-300
             hover:border-zinc-600 hover:bg-zinc-900/80"
    >
      <span>{label}</span>
    </button>

    <!-- PANEL -->
    <div
    class="absolute right-0 top-full -mt-px w-80

            border border-zinc-800
            bg-zinc-950/95 backdrop-blur-xl
            shadow-[0_12px_40px_rgba(0,0,0,0.5)]

            opacity-0 translate-y-2
            pointer-events-none

            transition duration-200 ease-out

            group-hover:opacity-100
            group-hover:translate-y-0
            group-hover:pointer-events-auto

            group-focus-within:opacity-100
            group-focus-within:translate-y-0
            group-focus-within:pointer-events-auto"
    >
    <div class="border-b border-zinc-800 px-4 py-3">
        {title && (
        <div class="text-xs uppercase tracking-[0.2em] text-zinc-400">
            {title}
        </div>
        )}
    </div>

    <div class="p-3 space-y-2">
        {links.map((link) => (
        <Link
            href={link.href}
            text={link.text ?? "Open"}
            icon=""
            external
        />
        ))}
    </div>
    </div>

  </div>
</div>