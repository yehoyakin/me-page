---
import Link from "./Link.astro";

interface LinkItem {
  href: string;
  text?: string;
  image?: string;
}

interface Position {
  top?: string;
  left?: string;
  right?: string;
  bottom?: string;
}

interface Props {
  links?: LinkItem[];
  title?: string;
  label?: string;
  position?: Position;
}

const {
  links = [],
  title = "",
  label = "Get it here!",
  position = { top: "1.5rem", left: "1.5rem" },
} = Astro.props as Props;

const top = position.top ?? "auto";
const left = position.left ?? "auto";
const right = position.right ?? "auto";
const bottom = position.bottom ?? "auto";

function iconFor(image?: string, href?: string) {
  if (image) {
    const key = image.toLowerCase();
    switch (true) {
      case key.includes("steam"):
        return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M12.5 10.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM12 2a10 10 0 100 20 10 10 0 000-20zM7.3 15.2a2.5 2.5 0 114.6-.2l4.1-2.3a3 3 0 10-.9-1.6l-4.3 2.4a2.5 2.5 0 11-3.5 1.3z"/></svg>`;
      case key.includes("gog"):
        return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/></svg>`;
      case key.includes("epic"):
        return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M5 4h14v2H5zM5 10h14v2H5zM5 16h14v2H5z"/></svg>`;
      case key.includes("xbox"):
        return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm3.3 6.2c.5.3 1 .7 1.5 1.3-1 .6-2 1-3.2 1.1.5-.9 1-1.8 1.7-2.4zM8.7 8.2c.8.7 1.3 1.7 1.8 2.6C8.8 11 7.8 10.4 6.8 9.9c.5-.6 1-1 1.9-1.7z"/></svg>`;
      default:
        return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M3.9 12a8.1 8.1 0 1116.2 0 8.1 8.1 0 01-16.2 0zM11 7h2v6h-2zM11 15h2v2h-2z"/></svg>`;
    }
  }

  const host = (href || "").toLowerCase();
  switch (true) {
    case host.includes("steam"):
      return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M12.5 10.5a1.5 1.5 0 11-3 0 1.5 1.5 0 013 0zM12 2a10 10 0 100 20 10 10 0 000-20zM7.3 15.2a2.5 2.5 0 114.6-.2l4.1-2.3a3 3 0 10-.9-1.6l-4.3 2.4a2.5 2.5 0 11-3.5 1.3z"/></svg>`;
    case host.includes("gog"):
      return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2z"/></svg>`;
    case host.includes("epic"):
      return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M5 4h14v2H5zM5 10h14v2H5zM5 16h14v2H5z"/></svg>`;
    case host.includes("xbox"):
      return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M12 2C6.5 2 2 6.5 2 12s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm3.3 6.2c.5.3 1 .7 1.5 1.3-1 .6-2 1-3.2 1.1.5-.9 1-1.8 1.7-2.4zM8.7 8.2c.8.7 1.3 1.7 1.8 2.6C8.8 11 7.8 10.4 6.8 9.9c.5-.6 1-1 1.9-1.7z"/></svg>`;
    default:
      return `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4"><path d="M3.9 12a8.1 8.1 0 1116.2 0 8.1 8.1 0 01-16.2 0zM11 7h2v6h-2zM11 15h2v2h-2z"/></svg>`;
  }
}
---

<div class="fixed z-[60]" style={`top: ${top}; left: ${left}; right: ${right}; bottom: ${bottom};`}>
  <div class="group relative">
    <button class="flex items-center gap-2 rounded-full border border-zinc-700 bg-zinc-950/95 px-4 py-2 text-sm font-semibold text-zinc-100 shadow-xl shadow-black/25 backdrop-blur-md transition hover:border-zinc-500">
      <span class="inline-flex h-2.5 w-2.5 rounded-full bg-emerald-400" />
      <span>{label}</span>
    </button>

    <div class="absolute left-0 top-full mt-1 hidden w-72 origin-top-left rounded-3xl border border-zinc-800 bg-zinc-950/95 p-4 shadow-2xl shadow-black/40 backdrop-blur-2xl transition duration-300 group-hover:block focus-within:block group-hover:pointer-events-auto">
      {title && <div class="mb-3 text-sm font-semibold text-slate-200">{title}</div>}
      <div class="space-y-2">
        {links.map((link) => (
          <Link
            href={link.href}
            text={link.text ?? "Open"}
            icon={iconFor(link.image, link.href)}
            external
          />
        ))}
      </div>
    </div>
  </div>
</div>
