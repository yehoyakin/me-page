---
import Title from "../Text/Title.astro";
import Body from "../Text/Body.astro";
import { uiDictionary } from "../../config/uiDictionary";
import type { ProjectRole, UiVariant } from "../../config/uiDictionary";

interface Props {
  tag: string;
  title: string;
  shortDescription: string;
  fullDescription?: string;
  roles?: ProjectRole[];
  variant?: UiVariant;
  class?: string;
  backgroundImage?: string;
}

const roleLabels: Record<ProjectRole, string> = {
  lead_programmer: "Lead Programmer",
  ui: "UI",
  game_design: "Game Design",
  art: "Art",
  audio: "Audio",
  tech_art: "Tech Art",
  systems: "Systems",
  tools: "Tools",
  developer: "Developer"
};

const {
  tag,
  title,
  shortDescription,
  fullDescription = "",
  roles = [],
  variant = "primary",
  class: extraClass = "",
  backgroundImage
} = Astro.props;

const config = uiDictionary[variant];

const themeColorClass =
  config.theme === "primary"
    ? "group-hover:text-retro-primary"
    : config.theme === "secondary"
    ? "group-hover:text-retro-secondary"
    : "group-hover:text-retro-terminal";

const baseText =
  "text-white text-lg transition-colors duration-300 retro-outline";

const cardClasses = [
  "group relative rounded-none border border-zinc-800",
  "overflow-visible",
  "w-full",
  "min-h-[380px]",
  "h-[55vh]",
  "hover:h-auto",
  "hover:min-h-[55vh]",
  "hover:z-20",
  "transition-all duration-500 ease-in-out",
  extraClass
].join(" ");
---

<div class={cardClasses} data-theme={config.transition}>

  {backgroundImage && (
    <div class="absolute inset-0 overflow-hidden z-0 bg-zinc-950">

      <img
        src={backgroundImage}
        class="
          absolute inset-0
          w-full h-full
          object-contain
          object-center

          scale-100
          transition duration-700 ease-out

          group-hover:scale-105
          group-hover:brightness-50
        "
        alt=""
      />

      <div
        class="
          absolute inset-0
          bg-gradient-to-b
          from-zinc-950/10
          via-transparent
          to-zinc-950/70
          transition duration-500
        "
      />

      <div
        class="
          absolute inset-0
          bg-transparent
          group-hover:bg-zinc-950/40
          transition duration-500
        "
      />

    </div>
  )}

  <div
    class="
      relative z-50
      w-full
      p-4 sm:p-6
      bg-zinc-950/85
    "
  >

    {tag && (
      <span
        class={`
          text-sm uppercase tracking-[0.3em]
          ${baseText}
          ${themeColorClass}
        `}
      >
        {tag}
      </span>
    )}

    <Title
      class={`
        mt-3 text-4xl sm:text-5xl md:text-6xl
        ${baseText}
        ${themeColorClass}
      `}
    >
      {title}
    </Title>

    <Body
      class={`
        mt-4 font-semibold text-base sm:text-lg
        ${baseText}
        ${themeColorClass}
      `}
    >
      {shortDescription}
    </Body>

  </div>

  {fullDescription && (
    <div
      class="
        relative z-10
        m-3 sm:m-4
        p-4 sm:p-6

        bg-zinc-950/95
        border border-zinc-800/80
        backdrop-blur-md
        rounded-none

        opacity-0
        translate-y-4

        transition-all duration-300 ease-[steps(60)]

        group-hover:opacity-100
        group-hover:translate-y-0
      "
    >

      <div
        class="space-y-6 sm:space-y-8 prose prose-invert max-w-none text-sm sm:text-base"
        set:html={fullDescription}
      />

      {roles.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {roles.map((role) => (
            <span
              class="
                text-[10px] sm:text-xs
                px-2 py-1
                rounded-none

                bg-zinc-900
                text-white
                retro-outline

                border border-zinc-800
              "
            >
              {roleLabels[role]}
            </span>
          ))}
        </div>
      )}

      <div class="mt-8 sm:mt-12 flex flex-wrap gap-3 sm:gap-4">
        <slot name="links" />
      </div>

    </div>
  )}

</div>