---
import Title from "../Text/Title.astro";
import Body from "../Text/Body.astro";
import { uiDictionary } from "../../config/uiDictionary";
import type { ProjectRole, UiVariant } from "../../config/uiDictionary";

interface Props {
  tag: string;
  title: string;
  shortDescription: string;
  fullDescription?: string;
  roles?: ProjectRole[];
  variant?: UiVariant;
  class?: string;
  backgroundImage?: string;
}

const roleLabels: Record<ProjectRole, string> = {
  lead_programmer: "Lead Programmer",
  ui: "UI",
  game_design: "Game Design",
  art: "Art",
  audio: "Audio",
  tech_art: "Tech Art",
  systems: "Systems",
  tools: "Tools",
  developer: "Developer"
};

const {
  tag,
  title,
  shortDescription,
  fullDescription = "",
  roles = [],
  variant = "primary",
  class: extraClass = "",
  backgroundImage
} = Astro.props;

const config = uiDictionary[variant];

const dynamicToken =
  config.theme === "primary"
    ? "var(--retro-primary)"
    : config.theme === "secondary"
      ? "var(--retro-secondary)"
      : "var(--retro-terminal)";

const themeColorClass =
  config.theme === "primary"
    ? "group-hover:text-[color:var(--retro-primary)] group-[[data-active=true]]:text-[color:var(--retro-primary)]"
    : config.theme === "secondary"
      ? "group-hover:text-[color:var(--retro-secondary)] group-[[data-active=true]]:text-[color:var(--retro-secondary)]"
      : "group-hover:text-[color:var(--retro-terminal)] group-[[data-active=true]]:text-[color:var(--retro-terminal)]";

const COLLAPSED_CARD_VIEWPORT_HEIGHT = "45vh"; 
const MINIMUM_COLLAPSED_CARD_HEIGHT = "360px"; 
const EXPANDED_CARD_BORDER_THICKNESS = "8px";
const CARD_EXPANSION_DURATION_MS = 200;
const DRAWER_REVEAL_DURATION_MS = 200;
const DRAWER_REVEAL_VERTICAL_OFFSET = "20px";
const PIXELATED_TRANSITION_STEPS = 200;

const baseText =
  "text-white text-lg transition-colors duration-150 ease-[steps(200)] retro-outline";

const cardClasses = [
  "group retro-expandable-card relative rounded-none border border-zinc-900 bg-zinc-950",
  "w-full overflow-hidden select-none",
  extraClass
].join(" ");
---

<div
  class={cardClasses}
  data-theme={config.transition}
  data-active="false"
  style={`
    --current-token: ${dynamicToken};
    --collapsed-card-height: ${COLLAPSED_CARD_VIEWPORT_HEIGHT};
    --collapsed-card-min-height: ${MINIMUM_COLLAPSED_CARD_HEIGHT};
    --expanded-card-border-width: ${EXPANDED_CARD_BORDER_THICKNESS};
    --drawer-offset: ${DRAWER_REVEAL_VERTICAL_OFFSET};
    --card-transition-duration: ${CARD_EXPANSION_DURATION_MS}ms;
    --drawer-transition-duration: ${DRAWER_REVEAL_DURATION_MS}ms;
    --pixel-transition-steps: ${PIXELATED_TRANSITION_STEPS};
  `}
  onclick="
    const state = this.getAttribute('data-active') === 'true';
    document
      .querySelectorAll('.retro-expandable-card')
      .forEach(card => card.setAttribute('data-active', 'false'));
    this.setAttribute('data-active', state ? 'false' : 'true');
  "
>
  {/* FIXED: Restored rich image brightness visibility and adjusted multi-layer overlays */}
  {backgroundImage && (
    <div class="card-image-wrapper absolute inset-0 w-full h-full z-0 bg-zinc-950 pointer-events-none">
      <img
        src={backgroundImage}
        class="card-dynamic-img w-full h-full object-cover object-center scale-100 filter brightness-[0.65] contrast-[1.1] transition-all duration-500 ease-out group-hover:scale-102"
        style="transition-duration: var(--card-transition-duration);"
        alt=""
      />
      {/* Protects left-aligned title text area with a controlled fade gradient mapping */}
      <div class="absolute inset-0 bg-gradient-to-r from-zinc-950/90 via-zinc-950/40 to-transparent pointer-events-none" />
      {/* Ambient occlusion vignette layout baseline shade */}
      <div class="absolute inset-0 bg-gradient-to-t from-zinc-950/90 via-transparent to-zinc-950/20 pointer-events-none" />
    </div>
  )}

  <div class="card-split-container flex w-full h-full relative z-10">
    <div class="card-left-content w-full flex flex-col justify-between h-full">
      
      <div class="w-full flex flex-col h-full justify-between">
        {/* FIXED: Removed solid 'bg-zinc-950/85' block overlay panel so the background image shows completely through */}
        <div class="w-full p-4 sm:p-6 bg-transparent md:max-w-xl pointer-events-none">
          {tag && (
            <span class={`text-xs sm:text-sm uppercase tracking-[0.3em] ${baseText} ${themeColorClass}`}>
              {tag}
            </span>
          )}

          <Title class={`mt-3 text-4xl sm:text-5xl md:text-6xl ${baseText} ${themeColorClass}`}>
            {title}
          </Title>

          <Body class={`mt-4 font-semibold text-sm sm:text-base ${baseText} ${themeColorClass}`}>
            {shortDescription}
          </Body>
        </div>

        <div class="p-4 sm:p-6 mt-auto">
          <div class="mb-4">
            <slot name="links" />
          </div>
          <div class="project-description-hint font-bold retro-outline text-white">
            CLICK FOR MORE
          </div>
        </div>
      </div>

      <div class="p-4 sm:p-6 w-full relative z-20">
        {fullDescription && (
          <div class="project-preview">
            <div class="project-description-preview">
              <div
                class="space-y-6 sm:space-y-8 prose prose-invert max-w-none text-sm sm:text-base text-zinc-300"
                set:html={fullDescription}
              />
            </div>
          </div>
        )}

        {fullDescription && (
          <div class="project-drawer">
            <div class="p-4 sm:p-6 bg-zinc-950/95 border border-zinc-800/80 backdrop-blur-md max-w-4xl">
              <div
                class="space-y-6 sm:space-y-8 prose prose-invert max-w-none text-sm sm:text-base text-zinc-300"
                set:html={fullDescription}
              />

              {roles.length > 0 && (
                <div class="mt-6 flex flex-wrap gap-2">
                  {roles.map((role) => (
                    <span class="text-[10px] sm:text-xs px-2 py-1 rounded-none bg-zinc-900 text-zinc-300 font-mono border border-zinc-800/80">
                      {roleLabels[role]}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </div>
        )}
      </div>
    </div>
  </div>
</div>

<style>
.retro-expandable-card {
  height: max(var(--collapsed-card-height), var(--collapsed-card-min-height));
  z-index: 1;
  border-color: rgba(63, 63, 70, 0.4);
  transition: border-color 150ms ease, height var(--card-transition-duration) cubic-bezier(0.16, 1, 0.3, 1);
}

.card-split-container {
  height: 100%;
}

.card-left-content {
  width: 100%;
}

.retro-expandable-card .project-drawer {
  opacity: 0;
  transform: translateY(var(--drawer-offset));
  visibility: hidden;
  height: 0;
  overflow: hidden;
  transition: all var(--drawer-transition-duration) steps(var(--pixel-transition-steps));
}

/* =========================================================
   ACTIVE CLICK STATES
   ========================================================= */

.retro-expandable-card[data-active="true"] {
  height: auto;
  min-height: max(var(--collapsed-card-height), var(--collapsed-card-min-height));
  z-index: 30;
  border: var(--expanded-card-border-width) solid var(--current-token);
}

.retro-expandable-card[data-active="true"] .card-dynamic-img {
  filter: blur(12px) brightness(25%) contrast(110%);
  scale: 1.05;
}

.retro-expandable-card[data-active="true"] .project-drawer {
  opacity: 1;
  transform: translateY(0);
  visibility: visible;
  height: auto;
}

.project-links-bar {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  padding: 1rem;
  border-top: 1px solid rgba(63, 63, 70, 0.4);
  background: rgba(24, 24, 27, 0.9);
  backdrop-filter: blur(8px);
  transition: border-color 150ms ease, background-color 150ms ease;
}
.retro-expandable-card:hover .project-links-bar {
  border-color: var(--current-token);
}
.project-description-preview {
  position: relative;
  max-height: 4.5rem;
  overflow: hidden;
  opacity: 0.35;
  transition: opacity 150ms ease, max-height 200ms ease;
}
.project-description-preview::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 2.5rem;
  background: linear-gradient(to bottom, transparent, rgba(9, 9, 11, 1));
  pointer-events: none;
}
.project-description-hint {
  margin-top: 0.75rem;
  font-size: 0.75rem;
  letter-spacing: 0.25em;
  text-transform: uppercase;
  opacity: 0.7;
  color: var(--current-token);
  transition: opacity 150ms ease;
}
.retro-expandable-card:hover .project-description-preview {
  opacity: 0.55;
}
.retro-expandable-card:hover .project-description-hint {
  opacity: 1;
}
.retro-expandable-card[data-active="true"] .project-description-preview {
  max-height: none;
  opacity: 1;
}
.retro-expandable-card[data-active="true"] .project-description-preview::after {
  display: none;
}
.retro-expandable-card[data-active="true"] .project-description-hint {
  display: none;
}
.project-preview {
  padding: 0;
}
.retro-expandable-card[data-active="true"] .project-preview {
  display: none;
}
</style>