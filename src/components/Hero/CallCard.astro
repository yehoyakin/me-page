---
import Title from "../Text/Title.astro";
import Body from "../Text/Body.astro";
import { uiDictionary } from "../../config/uiDictionary";
import type { ProjectRole, UiVariant } from "../../config/uiDictionary";

interface Props {
  tag: string;
  title: string;
  shortDescription: string;
  fullDescription?: string;
  roles?: ProjectRole[];
  variant?: UiVariant;
  class?: string;
  backgroundImage?: string;
}

const roleLabels: Record<ProjectRole, string> = {
  lead_programmer: "Lead Programmer",
  ui: "UI",
  game_design: "Game Design",
  art: "Art",
  audio: "Audio",
  tech_art: "Tech Art",
  systems: "Systems",
  tools: "Tools",
  developer: "Developer"
};

const {
  tag,
  title,
  shortDescription,
  fullDescription = "",
  roles = [],
  variant = "primary",
  class: extraClass = "",
  backgroundImage
} = Astro.props;

const config = uiDictionary[variant];

const themeColorClass =
  config.theme === "primary"
    ? "group-hover:text-retro-primary"
    : config.theme === "secondary"
    ? "group-hover:text-retro-secondary"
    : "group-hover:text-retro-terminal";

const baseText =
  "text-white text-lg transition-colors duration-300 retro-outline";

/**
 * 🔥 KEY IDEA:
 * fixed base height + expandable max-height
 */
const cardClasses = [
  "group relative overflow-hidden rounded-2xl border border-zinc-800",
  "w-full h-[500px]",

  "transition-[height] duration-500 ease-in-out",

  "hover:h-auto",

  "hover:z-20",

  extraClass
].join(" ");
---

<div class={cardClasses} data-theme={config.transition}>

  <!-- BACKGROUND -->
  {backgroundImage && (
    <div class="absolute inset-0 overflow-hidden z-0">
      <img
        src={backgroundImage}
        class="
          h-full w-full object-cover
          scale-105 brightness-100
          transition duration-700

          group-hover:scale-110
          group-hover:brightness-50
        "
      />

      <div class="
        absolute inset-0
        bg-transparent
        group-hover:bg-zinc-950/60
        transition
      " />
    </div>
  )}

  <!-- BANNER (always visible) -->
  <div class="
    relative z-20
    w-full p-8

    bg-zinc-950/85
    backdrop-blur-md
    border-b border-zinc-800
  ">

    <span class={`
      text-sm uppercase tracking-[0.3em]
      ${baseText}
      ${themeColorClass}
    `}>
      {tag}
    </span>

    <Title class={`
      mt-3 text-5xl md:text-6xl
      ${baseText}
      ${themeColorClass}
    `}>
      {title}
    </Title>

    <Body class={`
      mt-4 font-semibold text-lg
      ${baseText}
      ${themeColorClass}
    `}>
      {shortDescription}
    </Body>

  </div>

  <!-- EXPANDING CONTENT (THIS MAKES IT "GROW") -->
  {fullDescription && (
    <div class="
      relative z-10
      p-8

      opacity-0
      translate-y-4

      transition-all duration-500

      group-hover:opacity-100
      group-hover:translate-y-0
    ">

      <Body class="text-zinc-100 text-base retro-outline">
        {fullDescription}
      </Body>

      {roles.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {roles.map((role) => (
            <span class="
              text-xs px-2 py-1 rounded-md
              bg-zinc-900 text-white retro-outline
            ">
              {roleLabels[role]}
            </span>
          ))}
        </div>
      )}

      <div class="mt-6 flex flex-wrap gap-4">
        <slot name="links" />
      </div>

    </div>
  )}

</div>