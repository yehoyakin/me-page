---
import Title from "../Text/Title.astro";
import Body from "../Text/Body.astro";
import { uiDictionary } from "../../config/uiDictionary";
import type { ProjectRole, UiVariant } from "../../config/uiDictionary";

interface Props {
  tag: string;
  title: string;
  shortDescription: string;
  fullDescription?: string;

  roles?: ProjectRole[]; // 👈 NEW

  variant?: UiVariant;
  class?: string;
  backgroundImage?: string;
}

const roleLabels: Record<ProjectRole, string> = {
  lead_programmer: "Lead Programmer",
  ui: "UI",
  game_design: "Game Design",
  art: "Art",
  audio: "Audio",
  tech_art: "Tech Art",
  systems: "Systems",
  tools: "Tools",
  developer: "Developer"
};

const {
  tag,
  title,
  shortDescription,
  fullDescription = "",
  roles = [], // 👈 NEW DEFAULT
  variant = "primary",
  class: extraClass = "",
  backgroundImage
} = Astro.props;

const config = uiDictionary[variant];

/* =========================
   HOVER ACCENT COLOR
   ========================= */
const themeColorClass =
  config.theme === "primary"
    ? "group-hover:text-retro-primary"
    : config.theme === "secondary"
    ? "group-hover:text-retro-secondary"
    : "group-hover:text-retro-terminal";

/* =========================
   DEFAULT TEXT STYLE
   - black text
   - bold
   - WHITE OUTLINE (key fix)
   ========================= */
const baseText =
  "text-white text-lg transition-colors duration-300 retro-outline";

/* =========================
   CARD WRAPPER
   ========================= */
const cardClasses = [
  "group relative overflow-hidden rounded-2xl border border-zinc-800",
  "min-h-[450px] transition-all duration-500",
  `font-${config.font}`,
  extraClass
].join(" ");
---

<div class={cardClasses} data-theme={config.transition}>

  <!-- =========================
       BACKGROUND IMAGE
       DEFAULT: slightly blurred + dimmed
       HOVER: sharp + zoom + darker
  ========================== -->
  {backgroundImage && (
    <div class="absolute inset-0 overflow-hidden">
      <img
        src={backgroundImage}
        class="
          h-full w-full
          object-cover

          /* DEFAULT */
          blur-[1.5px] brightness-90 scale-105

          /* HOVER */
          transition-all duration-700
          group-hover:blur-0
          group-hover:scale-150
          group-hover:brightness-50
        "
      />

      <div class="
        absolute inset-0
        bg-zinc-950/20
        group-hover:bg-zinc-950/70
        transition
      " />
    </div>
  )}

  <!-- =========================
       CONTENT
  ========================== -->
  <div class="relative z-10 flex h-full flex-col justify-center p-10">

    <!-- TAG -->
    <span class={`
      text-sm uppercase tracking-[0.3em]
      ${baseText}
      ${themeColorClass}
    `}>
      {tag}
    </span>

    <!-- TITLE -->
    <Title class={`
      mt-3 text-5xl md:text-6xl
      ${baseText}
      ${themeColorClass}
    `}>
      {title}
    </Title>

    <!-- SHORT DESCRIPTION -->
    <Body class={`
    mt-4
    ${baseText}
    font-semibold
    text-lg
    leading-relaxed
    transition-colors duration-300
    ${themeColorClass}
    `}>

    {shortDescription}
    </Body>
    
    <!-- EXPANDED CONTENT -->
    <div class="
      overflow-hidden
      max-h-0
      opacity-0
      transition-all duration-500
      group-hover:max-h-[400px]
      group-hover:opacity-100
    ">

      {fullDescription && (
        <Body class="mt-6 text-zinc-100 text-base retro-outline">
          {fullDescription}
        </Body>
      )}


      <div class="mt-8 flex flex-wrap gap-4">
        <slot name="links" />
      </div>

          {roles.length > 0 && (
  <div class="mt-6 flex flex-wrap gap-2">
    {roles.map((role) => (
    <span class="text-xs px-2 py-1 rounded-md bg-zinc-950/80 text-white retro-outline">
        {roleLabels[role]}
      </span>
    ))}
  </div>
)}

    </div>

  </div>
</div>