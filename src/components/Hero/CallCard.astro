---
import Title from "../Text/Title.astro";
import Body from "../Text/Body.astro";
import { uiDictionary } from "../../config/uiDictionary";
import type { ProjectRole, UiVariant } from "../../config/uiDictionary";

interface Props {
  tag: string;
  title: string;
  shortDescription: string;
  fullDescription?: string;
  roles?: ProjectRole[];
  variant?: UiVariant;
  class?: string;
  backgroundImage?: string;
}

const roleLabels: Record<ProjectRole, string> = {
  lead_programmer: "Lead Programmer",
  ui: "UI",
  game_design: "Game Design",
  art: "Art",
  audio: "Audio",
  tech_art: "Tech Art",
  systems: "Systems",
  tools: "Tools",
  developer: "Developer"
};

const {
  tag,
  title,
  shortDescription,
  fullDescription = "",
  roles = [],
  variant = "primary",
  class: extraClass = "",
  backgroundImage
} = Astro.props;

const config = uiDictionary[variant];

// 💡 Dynamically resolve CSS variable tokens depending on the incoming project data entry variants
const dynamicToken = 
  config.theme === "primary"
    ? "var(--retro-primary)"
    : config.theme === "secondary"
    ? "var(--retro-secondary)"
    : "var(--retro-terminal)";

const themeColorClass =
  config.theme === "primary"
    ? "group-hover:text-[color:var(--retro-primary)]"
    : config.theme === "secondary"
    ? "group-hover:text-[color:var(--retro-secondary)]"
    : "group-hover:text-[color:var(--retro-terminal)]";

const baseText =
  "text-white text-lg transition-colors duration-150 ease-[steps(2)] retro-outline";

const cardClasses = [
  "group relative rounded-none border border-zinc-900 bg-zinc-950/60",
  "overflow-hidden",
  "w-full",
  "h-[55vh] min-h-[380px] max-h-[650px]",
  "hover:h-auto hover:min-h-[55vh]",
  "hover:z-20",
  /* 💡 Added blocky 2D structural shadow on interaction maps */
  "hover:shadow-[4px_4px_0px_0px_var(--current-token)]",
  "transition-all duration-150 ease-[steps(4)]",
  extraClass
].join(" ");
---

<div 
  class={cardClasses} 
  data-theme={config.transition}
  style={`--current-token: ${dynamicToken}; border-color: rgba(63, 63, 70, 0.4);`}
>

  {backgroundImage && (
    <div class="absolute inset-0 overflow-hidden z-0 bg-zinc-950">
      <img
        src={backgroundImage}
        class="
          absolute inset-0
          w-full h-full
          object-cover
          object-center

          scale-100
          transition duration-150 ease-[steps(2)]

          group-hover:scale-105
          group-hover:brightness-50
        "
        alt=""
      />

      <div class="absolute inset-0 bg-gradient-to-b from-zinc-950/10 via-transparent to-zinc-950/70 transition duration-150" />
      <div class="absolute inset-0 bg-transparent group-hover:bg-zinc-950/40 transition duration-150" />
    </div>
  )}

  <span class="scanline"></span>

  <div class="relative z-50 w-full p-4 sm:p-6 bg-zinc-950/85 border-b border-zinc-900/50">
    {tag && (
      <span class={`text-xs sm:text-sm uppercase tracking-[0.3em] ${baseText} ${themeColorClass}`}>
        {tag}
      </span>
    )}

    <Title class={`mt-3 text-4xl sm:text-5xl md:text-6xl ${baseText} ${themeColorClass}`}>
      {title}
    </Title>

    <Body class={`mt-4 font-semibold text-sm sm:text-base ${baseText} ${themeColorClass}`}>
      {shortDescription}
    </Body>
  </div>

  {fullDescription && (
    <div class="
      relative z-10
      m-3 sm:m-4
      p-4 sm:p-6

      bg-zinc-950/95
      border border-zinc-800/80
      backdrop-blur-md
      rounded-none

      opacity-0
      translate-y-4

      transition-all duration-150 ease-[steps(4)]

      group-hover:opacity-100
      group-hover:translate-y-0
    ">

      <div class="space-y-6 sm:space-y-8 prose prose-invert max-w-none text-sm sm:text-base" set:html={fullDescription} />

      {roles.length > 0 && (
        <div class="mt-6 flex flex-wrap gap-2">
          {roles.map((role) => (
            <span class="text-[10px] sm:text-xs px-2 py-1 rounded-none bg-zinc-900 text-zinc-300 font-mono border border-zinc-800/80">
              {roleLabels[role]}
            </span>
          ))}
        </div>
      )}

      <div class="mt-8 sm:mt-12 flex flex-wrap gap-3 sm:gap-4 items-center">
        <slot name="links" />
      </div>

    </div>
  )}

</div>

<style>
/* =========================
   DYNAMIC CARD SCANLINE ENGINE
   ========================= */
.scanline {
  position: absolute;
  left: 0;
  top: -100%;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    to bottom,
    rgba(0, 0, 0, 0) 0%,
    var(--current-token) 50%,
    rgba(0, 0, 0, 0) 100%
  );
  opacity: 0;
  pointer-events: none;
  z-index: 5;
}

.group:hover .scanline {
  animation: scanSweep 400ms steps(8) forwards;
  opacity: 0.35;
}

@keyframes scanSweep {
  0% { top: -100%; }
  100% { top: 100%; }
}
</style>