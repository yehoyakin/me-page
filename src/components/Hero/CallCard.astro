---
import Title from "../Text/Title.astro";
import Body from "../Text/Body.astro";
import { uiDictionary } from "../../config/uiDictionary";
import type { ProjectRole, UiVariant } from "../../config/uiDictionary";

interface Props {
  tag: string;
  title: string;
  shortDescription: string;
  fullDescription?: string;
  roles?: ProjectRole[];
  variant?: UiVariant;
  class?: string;
  backgroundImage?: string;
}

const roleLabels: Record<ProjectRole, string> = {
  lead_programmer: "Lead Programmer",
  ui: "UI",
  game_design: "Game Design",
  art: "Art",
  audio: "Audio",
  tech_art: "Tech Art",
  systems: "Systems",
  tools: "Tools",
  developer: "Developer"
};

const {
  tag,
  title,
  shortDescription,
  fullDescription = "",
  roles = [],
  variant = "primary",
  class: extraClass = "",
  backgroundImage
} = Astro.props;

const config = uiDictionary[variant];

/* =========================================================
   VISUAL THEME CONFIGURATION
   ========================================================= */

const dynamicToken =
  config.theme === "primary"
    ? "var(--retro-primary)"
    : config.theme === "secondary"
      ? "var(--retro-secondary)"
      : "var(--retro-terminal)";

const themeColorClass =
  config.theme === "primary"
    ? "group-hover:text-[color:var(--retro-primary)] group-[[data-active=true]]:text-[color:var(--retro-primary)]"
    : config.theme === "secondary"
      ? "group-hover:text-[color:var(--retro-secondary)] group-[[data-active=true]]:text-[color:var(--retro-secondary)]"
      : "group-hover:text-[color:var(--retro-terminal)] group-[[data-active=true]]:text-[color:var(--retro-terminal)]";

/* =========================================================
   EXPANDABLE CARD LAYOUT CONFIGURATION
   ========================================================= */

const COLLAPSED_CARD_VIEWPORT_HEIGHT = "55vh";
const MINIMUM_COLLAPSED_CARD_HEIGHT = "380px";

const EXPANDED_CARD_BORDER_THICKNESS = "8px";

const COLLAPSED_CARD_STACKING_PRIORITY = 1;
const EXPANDED_CARD_STACKING_PRIORITY = 30;

/* =========================================================
   DRAWER ANIMATION CONFIGURATION
   ========================================================= */

const DRAWER_REVEAL_VERTICAL_OFFSET = "20px";

const CARD_EXPANSION_DURATION_MS = 200;
const DRAWER_REVEAL_DURATION_MS = 200;

const PIXELATED_TRANSITION_STEPS = 100;

/* =========================================================
   EXPANDED CARD BEHAVIOR CONFIGURATION
   ========================================================= */

const EXPANDED_CARD_ATTACHMENT_MODE = "align-start";
/*
  center
  align-start
  align-end
*/

const baseText =
  "text-white text-lg transition-colors duration-150 ease-[steps(2)] retro-outline";

const cardClasses = [
  "group retro-expandable-card relative rounded-none border border-zinc-900 bg-zinc-950/60",
  "w-full overflow-visible select-none",
  extraClass
].join(" ");
---

<div
  class={cardClasses}
  data-theme={config.transition}
  data-expand-anchor={EXPANDED_CARD_ATTACHMENT_MODE}
  data-active="false"
  style={`
    --current-token: ${dynamicToken};

    --collapsed-card-height: ${COLLAPSED_CARD_VIEWPORT_HEIGHT};
    --collapsed-card-min-height: ${MINIMUM_COLLAPSED_CARD_HEIGHT};

    --expanded-card-border-width: ${EXPANDED_CARD_BORDER_THICKNESS};

    --drawer-offset: ${DRAWER_REVEAL_VERTICAL_OFFSET};

    --card-transition-duration: ${CARD_EXPANSION_DURATION_MS}ms;
    --drawer-transition-duration: ${DRAWER_REVEAL_DURATION_MS}ms;

    --pixel-transition-steps: ${PIXELATED_TRANSITION_STEPS};
  `}
  onclick="
    const state = this.getAttribute('data-active') === 'true';

    document
      .querySelectorAll('.retro-expandable-card')
      .forEach(card => card.setAttribute('data-active', 'false'));

    this.setAttribute('data-active', state ? 'false' : 'true');
  "
>
  {backgroundImage && (
    <div class="absolute inset-0 overflow-hidden z-0 bg-zinc-950 pointer-events-none">
      <img
        src={backgroundImage}
        class="
          absolute inset-0
          w-full h-full
          object-cover
          object-center
          scale-100
          transition
          duration-200
          ease-[steps(100)]
          group-hover:scale-105
          group-hover:brightness-50
        "
        alt=""
      />

      <div class="absolute inset-0 bg-gradient-to-b from-zinc-950/10 via-transparent to-zinc-950/80" />
    </div>
  )}

  <div class="relative z-10 w-full p-4 sm:p-6 bg-zinc-950/85 border-b border-zinc-900/50 pointer-events-none">
    {tag && (
      <span class={`text-xs sm:text-sm uppercase tracking-[0.3em] ${baseText} ${themeColorClass}`}>
        {tag}
      </span>
    )}

    <Title class={`mt-3 text-4xl sm:text-5xl md:text-6xl ${baseText} ${themeColorClass}`}>
      {title}
    </Title>

    <Body class={`mt-4 font-semibold text-sm sm:text-base ${baseText} ${themeColorClass}`}>
      {shortDescription}
    </Body>
  </div>

  {fullDescription && (
    <div class="project-drawer">
      <div class="p-4 sm:p-6 m-3 sm:m-4 bg-zinc-950/95 border border-zinc-800/80 backdrop-blur-md">
        <div
          class="space-y-6 sm:space-y-8 prose prose-invert max-w-none text-sm sm:text-base text-zinc-300"
          set:html={fullDescription}
        />

        {roles.length > 0 && (
          <div class="mt-6 flex flex-wrap gap-2">
            {roles.map((role) => (
              <span class="text-[10px] sm:text-xs px-2 py-1 rounded-none bg-zinc-900 text-zinc-300 font-mono border border-zinc-800/80">
                {roleLabels[role]}
              </span>
            ))}
          </div>
        )}

        <div class="mt-8 sm:mt-12 flex flex-wrap gap-3 sm:gap-4 items-center">
          <slot name="links" />
        </div>
      </div>
    </div>
  )}
</div>

<style>
.retro-expandable-card {
  height: var(--collapsed-card-height);
  min-height: var(--collapsed-card-min-height);

  z-index: 1;

  border-color: rgba(63, 63, 70, 0.4);

  transition:
    height var(--card-transition-duration)
      steps(var(--pixel-transition-steps)),
    border-color 150ms ease;
}

.retro-expandable-card .project-drawer {
  opacity: 0;

  transform: translateY(var(--drawer-offset));

  visibility: hidden;
  height: 0;

  overflow: hidden;

  transition:
    all var(--drawer-transition-duration)
      steps(var(--pixel-transition-steps));
}

.retro-expandable-card[data-active="true"] {
  height: auto;

  min-height: var(--collapsed-card-height);

  z-index: 30;

  border:
    var(--expanded-card-border-width)
    solid
    var(--current-token);
}

.retro-expandable-card[data-active="true"] .project-drawer {
  opacity: 1;

  transform: translateY(0);

  visibility: visible;

  height: auto;
}
</style>
