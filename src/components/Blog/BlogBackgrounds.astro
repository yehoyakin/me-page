---
interface BackgroundLayer {
  percent: number;
  image: string;
}

interface Props {
  backgrounds: BackgroundLayer[];
  heroImage: string;
  backgroundBlur: number;
  backgroundOpacity: number;
}

const { backgrounds = [], heroImage = "", backgroundBlur = 0, backgroundOpacity = 1 } = Astro.props as Props;
---

<div class="fixed inset-0 z-0 -top-20 overflow-hidden pointer-events-none">
  {backgrounds.length > 0 ? (
    backgrounds.map((bg, index) => (
      <div
        id={`dynamic-bg-${index}`}
        data-active={index === 0 ? "1" : "0"}
        class="absolute inset-0 bg-center bg-cover transition-opacity duration-700"
        style={`background-image: url('${bg.image}'); opacity: ${index === 0 ? backgroundOpacity : 0}; filter: blur(${backgroundBlur * 24}px); transform: translate3d(0,0,0);`}
      />
    ))
  ) : (
    <div
      id="dynamic-bg-0"
      data-active="1"
      class="absolute inset-0 bg-center bg-cover transition-opacity duration-700"
      style={`background-image: url('${heroImage}'); opacity: ${backgroundOpacity}; filter: blur(${backgroundBlur * 24}px); transform: translate3d(0,0,0);`}
    />
  )}

  <div
    id="dynamic-bg-blend"
    class="absolute inset-0 pointer-events-none"
    style={`mix-blend-mode: overlay; background: linear-gradient(to bottom, rgba(0,0,0,0.12), rgba(0,0,0,0.36)); opacity: ${Math.min(0.45, backgroundOpacity * 0.6)};`}
  />
</div>
