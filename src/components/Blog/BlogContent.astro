---
import { asset } from "../../utils/asset";

interface SceneItem {
  image: string;
  align?: "left" | "right" | "center";
}

interface Props {
  bodyHtml: string;
  scenes?: SceneItem[];
}

const { bodyHtml, scenes = [] } = Astro.props as Props;

/**
 * Replace [scene[x]] markers with images
 * SAFE for BOTH raw paths and asset() resolved paths
 */
const sceneHtml =
  Array.isArray(scenes) && scenes.length > 0
    ? bodyHtml.replace(/\[scene\[(\d+)\]\]/g, (match, index) => {
        const sceneIndex = parseInt(index, 10);
        const scene = scenes[sceneIndex];

        if (!scene?.image) return match;

        const align = (scene.align || "center").toLowerCase();

        let figureClass =
          "my-8 overflow-hidden rounded-2xl border border-zinc-800";

        let imgClass = "w-full h-auto";

        switch (align) {
          case "left":
            figureClass += " float-left max-w-[45%] mr-6 mb-4";
            break;

          case "right":
            figureClass += " float-right max-w-[45%] ml-6 mb-4";
            break;

          default:
            figureClass += " mx-auto w-full mb-6";
            break;
        }

        return `
          <figure class="${figureClass}">
            <img
              src="${asset(scene.image)}"
              alt="Scene ${sceneIndex}"
              class="${imgClass}"
            />
          </figure>
        `;
      })
    : bodyHtml;
---

<div
  class="prose prose-invert max-w-none rounded-[2rem]
         border border-zinc-800/50 bg-zinc-950/70
         p-8 backdrop-blur-md"
  id="blog-content"
>
  <div set:html={sceneHtml} />
</div>