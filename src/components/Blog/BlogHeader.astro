---
import Title from "../Text/Title.astro";
import Body from "../Text/Body.astro";

interface Props {
  title: string;
  description: string;
  date: Date;
}

const { title, description, date } = Astro.props as Props;
---

<header class="space-y-6 rounded-[2rem] border border-zinc-800/50 bg-zinc-950/70 p-8 backdrop-blur-md text-center">
  <p class="text-sm uppercase tracking-[0.3em] text-retro-primary">Blog</p>
  <Title level={1}  class="text-5xl md:text-6xl mx-auto">
    {title}
  </Title>
  <Body class="mx-auto max-w-3xl text-zinc-400 text-center">
    {description}
  </Body>
  <time class="mx-auto block text-sm text-zinc-500" datetime={date.toISOString()}>
    {date.toLocaleDateString()}
  </time>
</header>
