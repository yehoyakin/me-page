---
import LinkCard from "../Hero/LinkCard.astro";

interface CardItem {
  href?: string;
  tag?: string;
  title: string;
  description?: string;
  actionText?: string;
  backgroundImage?: string;
  links?: {
    href: string;
    text?: string;
    image?: string;
  }[];
}

interface Props {
  cards: CardItem[];
}

const { cards = [] } = Astro.props as Props;
---

<aside
  class="relative z-20 w-full lg:sticky lg:top-24 lg:h-fit
         lg:max-h-[calc(100vh-6rem)] overflow-y-auto retro-scrollbar"
>
  {cards.length > 0 && (
    /* 💡 FIXED: Removed rounded-2xl container curves and unified flat block layout look */
    <div
      class="space-y-6 rounded-none border border-zinc-800/60
             bg-zinc-950/60 backdrop-blur-xl
             p-4 shadow-[4px_4px_0px_0px_rgba(0,0,0,0.5)]"
    >
      {cards.map((card) => (
        /* 💡 FIXED: Changed individual wrapper rounded-xl to completely square edge elements */
        <div class="w-full overflow-hidden rounded-none border border-zinc-900/40 bg-zinc-950/40">
          <LinkCard
            href={card.href}
            links={card.links}
            tag={card.tag}
            title={card.title}
            description={card.description}
            actionText={card.actionText}
            backgroundImage={card.backgroundImage}
            class="h-auto"
          />
        </div>
      ))}
    </div>
  )}
</aside>

<style is:global>
  /* Clean retro-block scrollbar detailing for overflowing widget containers */
  .retro-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .retro-scrollbar::-webkit-scrollbar-track {
    background: rgba(9, 9, 11, 0.5);
  }
  .retro-scrollbar::-webkit-scrollbar-thumb {
    background: rgba(63, 63, 70, 0.8);
  }
</style>