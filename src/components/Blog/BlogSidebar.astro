---
import LinkCard from "../Hero/LinkCard.astro";

interface CardItem {
  href?: string;
  tag?: string;
  title: string;
  description?: string;
  actionText?: string;
  backgroundImage?: string;
  links?: {
    href: string;
    text?: string;
    image?: string;
  }[];
}

interface Props {
  cards: CardItem[];
}

const { cards = [] } = Astro.props as Props;
---

<aside
  class="relative z-20 w-full lg:sticky lg:top-24 lg:h-fit
         lg:max-h-[calc(100vh-6rem)] overflow-y-auto"
>
  {cards.length > 0 && (
    <div
      class="space-y-5 rounded-2xl border border-zinc-800/60
             bg-zinc-950/40 backdrop-blur-xl
             p-4 shadow-[0_20px_60px_-30px_rgba(0,0,0,0.8)]"
    >
      {cards.map((card) => (
        <div class="w-full overflow-hidden rounded-xl">
          <LinkCard
            href={card.href}
            links={card.links}
            tag={card.tag}
            title={card.title}
            description={card.description}
            actionText={card.actionText}
            backgroundImage={card.backgroundImage}
            class="h-auto"
          />
        </div>
      ))}
    </div>
  )}
</aside>