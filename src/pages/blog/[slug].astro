---
import MyLayout from "../../layouts/MyLayout.astro";
import BackLink from "../../components/Hero/BackLink.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: {
      slug: post.slug,
    },
    props: {
      post,
    },
  }));
}

const { post } = Astro.props;
let Content;
let notFound = false;

if (post) {
  const rendered = await post.render();
  Content = rendered.Content;
} else {
  notFound = true;
}
---

<MyLayout title={notFound ? "Post not found" : post.data.title}>
  <BackLink />

  <article class="prose prose-invert mx-auto py-16">
    {notFound ? (
      <div class="space-y-6">
        <header>
          <p class="text-sm uppercase tracking-[0.3em] text-retro-primary">Blog</p>
          <h1 class="mt-4 text-4xl font-semibold">Post not found</h1>
        </header>
        <p class="text-zinc-400">
          The blog post you tried to open does not exist or may have been removed.
        </p>
      </div>
    ) : (
      <div class="space-y-10">
        <header>
          <p class="text-sm uppercase tracking-[0.3em] text-retro-primary">Blog</p>
          <h1 class="mt-4 text-4xl font-semibold">{post.data.title}</h1>
          <p class="mt-4 text-zinc-400">{post.data.description}</p>
          <time class="mt-3 block text-sm text-zinc-500" datetime={post.data.date.toISOString()}>
            {new Date(post.data.date).toLocaleDateString()}
          </time>
        </header>

        <hr class="border-zinc-800" />

        <div class="prose prose-invert">
          <Content />
        </div>
      </div>
    )}
  </article>
</MyLayout>
---