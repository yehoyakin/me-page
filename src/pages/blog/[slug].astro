---
import MyLayout from "../../layouts/MyLayout.astro";
import BackLink from "../../components/Hero/BackLink.astro";
import BlogBackgrounds from "../../components/Blog/BlogBackgrounds.astro";
import BlogHeader from "../../components/Blog/BlogHeader.astro";
import BlogContent from "../../components/Blog/BlogContent.astro";
import BlogSidebar from "../../components/Blog/BlogSidebar.astro";
import TopLeftLinkWidget from "../../components/Hero/TopLeftLinkWidget.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  return posts.map((post) => ({
    params: {
      slug: post.id,
    },
  }));
}

const slug = Astro.params.slug;
const posts = await getCollection("blog");
const post = posts.find((entry) => entry.id === slug);

if (!post) {
  throw new Response("Post not found", { status: 404 });
}

const scenes = post.data.scenes ?? [];
const cards = post.data.cards ?? [];
const widgetPosition = post.data.widgetPosition ?? { top: "1.5rem", left: "1.5rem" };
const rawBackgrounds = post.data.backgrounds ?? [];
const backgrounds = rawBackgrounds
  .map((b) => ({ percent: b.percent <= 1 ? b.percent * 100 : b.percent, image: b.image }))
  .sort((a, b) => a.percent - b.percent);
const heroImage = post.data.background ?? "";
const backgroundBlur = post.data.backgroundBlur ?? 0;
const backgroundOpacity = post.data.backgroundOpacity ?? 1;
const backgroundParallax = post.data.backgroundParallax ?? 0.2;

const rendered = post.rendered?.html ?? "";
---

<MyLayout title={post.data.title} animation={post.data.theme ?? "grid"}>
    
  <BackLink href="/blog" text="← Back to blog" />

  <section class="relative grid gap-12 lg:grid-cols-[minmax(0,1fr)_360px] py-16">
    {(backgrounds.length > 0 || heroImage) && (
      <BlogBackgrounds
        backgrounds={backgrounds}
        heroImage={heroImage}
        backgroundBlur={backgroundBlur}
        backgroundOpacity={backgroundOpacity}
      />
    )}

    {cards.length > 0 && (
      <TopLeftLinkWidget
        title="Get it here!"
        links={(cards[0] as any).links}
        position={widgetPosition}
      />
    )}

    <main class="relative z-10 space-y-12">
      <BlogHeader
        title={post.data.title}
        description={post.data.description}
        date={post.data.date}
      />

    <BlogContent bodyHtml={rendered} scenes={scenes} />
    </main>

    <BlogSidebar cards={cards.slice(1)} />
  </section>

  <script define:vars={{ backgrounds, backgroundOpacity, backgroundBlur, backgroundParallax }}>
    const bgOpacity = backgroundOpacity ?? 1;
    const bgBlur = backgroundBlur ?? 0;
    const parallaxFactor = Number(backgroundParallax ?? 0.2);
    window.__backgrounds = backgrounds;

    const updateBackgrounds = () => {
      const scrollPosition = window.scrollY;
      const height = document.body.scrollHeight - window.innerHeight;
      const progress = height > 0 ? (scrollPosition / height) * 100 : 0;
      const bgs = window.__backgrounds || [];

      if (!bgs.length) return;

      const selectedIndex = bgs.findIndex((b) => progress <= b.percent);
      const activeIndex = selectedIndex !== -1 ? selectedIndex : bgs.length - 1;
      const offset = -window.scrollY * parallaxFactor;

      bgs.forEach((_, index) => {
        const bgEl = document.getElementById(`dynamic-bg-${index}`);
        if (!bgEl) return;
        bgEl.style.backgroundImage = `url('${bgs[index].image}')`;
        bgEl.style.filter = `blur(${bgBlur * 24}px)`;
        bgEl.style.transform = `translate3d(0, ${offset}px, 0)`;
        bgEl.style.opacity = index === activeIndex ? String(bgOpacity) : "0";
        bgEl.dataset.active = index === activeIndex ? "1" : "0";
      });
    };

    updateBackgrounds();
    window.addEventListener("scroll", updateBackgrounds, { passive: true });
  </script>
</MyLayout>
---