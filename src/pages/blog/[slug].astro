---
import MyLayout from "../../layouts/MyLayout.astro";
import BackLink from "../../components/Hero/BackLink.astro";
import BlogBackgrounds from "../../components/Blog/BlogBackgrounds.astro";
import BlogHeader from "../../components/Blog/BlogHeader.astro";
import BlogContent from "../../components/Blog/BlogContent.astro";
import BlogSidebar from "../../components/Blog/BlogSidebar.astro";
import { getCollection } from "astro:content";
import { asset } from "../../utils/asset";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
  }));
}

const slug = Astro.params.slug;
const posts = await getCollection("blog");
const post = posts.find((entry) => entry.id === slug);

if (!post) {
  throw new Response("Post not found", { status: 404 });
}

const cards = post.data.cards ?? [];

/* ✅ Normalize content scenes through asset */
const scenes = Array.isArray(post.data.scenes)
  ? post.data.scenes.map((s) => ({
      image: asset(s.image),
      align: s.align ?? "center",
    }))
  : [];

/* ✅ Normalize layers through asset */
const rawBackgrounds = post.data.backgrounds ?? [];
const backgrounds = Array.isArray(rawBackgrounds)
  ? rawBackgrounds
      .map((b) => ({
        percent: b.percent <= 1 ? b.percent * 100 : b.percent,
        image: asset(b.image),
      }))
      .sort((a, b) => a.percent - b.percent)
  : [];

/* ✅ Normalize single cover through asset */
const heroImage = post.data.background ? asset(post.data.background) : "";

const backgroundBlur = post.data.backgroundBlur ?? 0;
const backgroundOpacity = post.data.backgroundOpacity ?? 1;
const backgroundParallax = post.data.backgroundParallax ?? 0.2;

const rendered = post.rendered?.html ?? "";

// 💡 SANITIZE THE BASE PATH ROUTE FOR REDIRECT COMPATIBILITY
const baseUrl = import.meta.env.BASE_URL.endsWith("/")
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`;

// 💡 GATHER INTENSE PRELOAD ARRAYS AFTER ENGINES RUN
const imagesToPreload = [
  heroImage,
  ...backgrounds.map((b) => b.image)
].filter(Boolean);
---

<MyLayout 
  title={post.data.title} 
  animation={post.data.theme ?? "grid"} 
  preloadImages={imagesToPreload}
>
  
  <div class="relative z-30">
    <BackLink href={`${baseUrl}blog/`} text="← Back to blog" />
  </div>

  {/* 💡 MOBILE ACCESSIBLE CONTAINER GRID: Responsive layout structure drops layout constraints evenly on mobile viewports */}
  <section class="relative py-12 md:py-16 px-2 sm:px-4 max-w-7xl mx-auto w-full">
    
    {/* 1. LAYER RENDERING CONTAINER */}
    <BlogBackgrounds
      backgrounds={backgrounds}
      heroImage={heroImage}
      backgroundBlur={backgroundBlur}
      backgroundOpacity={backgroundOpacity}
    />

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 sm:gap-8 mt-12 w-full items-start">
      {/* 2. BODY GRAPH COLUMN */}
      <div class="grid grid-cols-1 lg:col-span-2 gap-6 sm:gap-8 w-full min-w-0">
        <BlogHeader
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
        />
        <BlogContent bodyHtml={rendered} scenes={scenes} />
      </div>

      {/* 3. SIDE RESPONSIVE WIDGET SYSTEM */}
      <div class="grid grid-cols-1 lg:col-span-1 w-full min-w-0">
        <BlogSidebar cards={cards} />
      </div>
    </div>
  </section>

  {/* 4. MOTION PARALLAX CONTROLLER */}
  <script define:vars={{
    backgrounds,
    backgroundOpacity,
    backgroundBlur,
    backgroundParallax
  }}>
    const bgOpacity = backgroundOpacity ?? 1;
    const bgBlur = backgroundBlur ?? 0;
    const parallaxFactor = Number(backgroundParallax ?? 0.2);

    window.__backgrounds = backgrounds;

    const updateBackgrounds = () => {
      const scrollPosition = window.scrollY;
      const height = document.body.scrollHeight - window.innerHeight;
      const progress = height > 0 ? (scrollPosition / height) * 100 : 0;

      const bgs = window.__backgrounds || [];
      if (!bgs.length) return;

      const selectedIndex = bgs.findIndex((b) => progress <= b.percent);
      const activeIndex = selectedIndex !== -1 ? selectedIndex : bgs.length - 1;

      const offset = -window.scrollY * parallaxFactor;

      bgs.forEach((_, index) => {
        const bgEl = document.getElementById(`dynamic-bg-${index}`);
        if (!bgEl) return;

        bgEl.style.backgroundImage = `url('${bgs[index].image}')`;
        bgEl.style.filter = `blur(${bgBlur * 24}px)`;
        bgEl.style.transform = `translate3d(0, ${offset}px, 0)`;
        bgEl.style.opacity = index === activeIndex ? String(bgOpacity) : "0";
        bgEl.dataset.active = index === activeIndex ? "1" : "0";
      });
    };

    updateBackgrounds();
    window.addEventListener("scroll", updateBackgrounds, { passive: true });
  </script>

</MyLayout>