---
import MyLayout from "../layouts/MyLayout.astro";
import Title from "../components/Text/Title.astro";
import Body from "../components/Text/Body.astro";
import BackLink from "../components/Hero/BackLink.astro";
import SocialLink from "../components/Hero/Link.astro";
import CallCard from "../components/Hero/CallCard.astro";
import { getCollection } from "astro:content";
import { asset } from "../utils/asset";

const rawProjects = await getCollection("projects");

const projects = await Promise.all(
  rawProjects.map(async (project) => {
    return {
      ...project,
      rendered: project.rendered?.html ?? "",
    };
  })
);

// 💡 Resolve the background asset parameters cleanly
const bgGif = asset("images/kbg2.gif");

// 💡 Build out preloads containing both background grids and main visual assets
const cardPreviews = projects.map((p) => asset(p.data.backgroundImage)).filter(Boolean);
const imagesToPreload = [bgGif, ...cardPreviews];
---

<MyLayout title="Portfolio | JoacoDev" animation="grid" preloadImages={imagesToPreload}>

  {/* 💡 FIXED: Master breakout layer container isolating stacking indices */}
  <div class="absolute inset-0 w-full min-h-screen overflow-x-hidden bg-zinc-950">

    {/* 💡 FIXED: Native GPU blur engine running at z-0 */}
    <div class="fixed inset-0 z-0 pointer-events-none style3d" style="filter: blur(4px); transform: scale(1.05);">
      <img
        src={bgGif}
        class="w-full h-full object-cover opacity-100"
        alt=""
        role="presentation"
      />
    </div>

    {/* 💡 FIXED: Hardware static overlay layer at z-10 protecting text contrast */}
    <div class="absolute inset-0 z-10 pointer-events-none" />

    {/* 💡 FIXED: Shifted navigation links and content into relative z-20 layers */}
    <div class="relative z-20 py-16 md:py-24 px-4 sm:px-6 md:px-8 max-w-7xl mx-auto w-full">
      
      <BackLink />

      <section class="mt-6 w-full">
        <Title class="mt-3 text-5xl md:text-6xl" level={1} variant="primary">
          Portfolio
        </Title>

        <Body variant="secondary" class="mt-4">
          Hover to inspect projects and reveal additional details.
        </Body>

        {/* 💡 GRID WRAPPER: Responsive grid elements rendered securely at z-20 */}
        <div class="mt-12 sm:mt-16 grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8 auto-rows-max items-start">
          {projects.map((project) => (
            <div style={`order: ${project.data.order ?? 0};`} class="w-full h-full min-h-0">
              <CallCard
                tag={project.data.tag}
                title={project.data.title}
                shortDescription={project.data.shortDescription}
                fullDescription={project.rendered}
                roles={project.data.roles}
                variant={project.data.variant}
                backgroundImage={asset(project.data.backgroundImage)}
              >
           <Fragment slot="links">
              {project.data.links && project.data.links.map((link) => (

                <SocialLink
                  href={link.href}
                  text={link.text}
                  external={true}
                />
              ))}
            </Fragment>
              </CallCard>
            </div>
          ))}
        </div>
      </section>
    </div>

  </div>

</MyLayout>