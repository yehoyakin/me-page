---
import MyLayout from "../layouts/MyLayout.astro";
import Title from "../components/Text/Title.astro";
import Body from "../components/Text/Body.astro";
import { getCollection } from "astro:content";
import type { BlogPost } from "../types/blog";
import BlogCard from "../components/Hero/BlogCard.astro";
import BackLink from "../components/Hero/BackLink.astro";
import { asset } from "../utils/asset";

const posts = (await getCollection("blog")) as BlogPost[];
const bgGif = asset("images/kbg1.gif");
---

<MyLayout title="Blog" animation="traversal" preloadImages={[bgGif]}>

  {/* 💡 FIXED: Uses absolute/fixed breakouts to isolate layers and prevent text vanishing acts */}
  <div class="absolute inset-0 w-full min-h-screen overflow-x-hidden bg-zinc-950">

    {/* 💡 FIXED: Native GPU blur filter matching the homepage breakout engine */}
    <div class="fixed inset-0 z-0 pointer-events-none style3d" style="filter: blur(4px); transform: scale(1.05);">
      <img
        src={bgGif}
        class="w-full h-full object-cover opacity-100"
        alt=""
        role="presentation"
      />
    </div>

    {/* 💡 FIXED: Dark tint layer matching home configuration stack */}
    <div class="absolute inset-0 z-10 pointer-events-none" />

    {/* 💡 FIXED: Section is lifted safely to z-20 so title, description, and list stay fully visible */}
    <section class="relative z-20 py-24 px-4 sm:px-6 md:px-8 max-w-7xl mx-auto w-full">
      <BackLink />

      <Title class="mt-3 text-5xl md:text-6xl" level={1} variant="primary">
        Blog
      </Title>

      <Body variant="secondary">
        Thoughts on my favorite art.
      </Body>

      <div class="mt-24" />

      <div class="space-y-10">
        {posts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
    </section>

  </div>

</MyLayout>