---
import MyLayout from "../layouts/MyLayout.astro";
import SplitLanding from "../components/Hero/SplitLanding.astro";
import ContactPanel from "../components/Hero/ContactPanel.astro";
import HeaderInfo from "../components/Hero/InfoHeader.astro";
import { asset } from "../utils/asset";
---

<MyLayout title="Home">

{/* 💡 BULLETPROOF BLUR SYSTEM: Moves the blur effect directly onto the graphic layer */}
  <div class="absolute inset-0 w-full h-full min-h-screen overflow-hidden bg-zinc-950">

    {/* 💡 FIXED: We use native 'filter: blur' and 'transform: translate3d' here.
        This forces the GPU to render the blur natively on all browsers without relying on backdrop sampling. */}
    <div class="fixed inset-0 z-0 pointer-events-none style3d" style="filter: blur(4px); transform: scale(1.05);">
      <img
        src={asset("images/kbg.gif")}
        class="w-full h-full object-cover opacity-100"
        alt=""
      />
    </div>

    {/* 💡 Clean, high-performance static dark overlay tint */}
    <div class="absolute inset-0 z-10 pointer-events-none" />

    <div class="relative z-20 flex h-full flex-col min-h-0 w-full">

      <header class="absolute top-0 right-0 px-8 py-6 z-50">
        <ContactPanel />
      </header>

      <HeaderInfo 
        name="Homepage"
        description="Joaquin Herrera / Game Developer"
        portraitSrc={asset("images/frontPage/me.png")}
        theme="secondary"
      />

      <div class="flex-1 min-h-0 w-full">
        <SplitLanding
          background=""
          left={{
            href: `${import.meta.env.BASE_URL}portfolio/`,
            tag: "My projects",
            title: "Portfolio",
            description: "Take a look at my Unity and Unreal Engine projects.",
            actionText: "View projects",
            imageSrc: asset("images/kbg2.gif"),
          }}
          right={{
            href: `${import.meta.env.BASE_URL}blog/`,
            tag: "My thoughts",
            title: "Blog",
            description: "Just my thoughts on videogames, game development and movies.",
            actionText: "Read articles",
            imageSrc: asset("images/kbg1.gif"),
          }}
          footerText="Pixel art by Kirokaze!."
        />
      </div>

    </div>
  </div>
</MyLayout>